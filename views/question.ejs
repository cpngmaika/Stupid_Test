<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Câu hỏi <%= id %> - <%= testTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-900 text-slate-200 min-h-screen py-12 px-4 selection:bg-cyan-500/30 flex items-center justify-center">

    <div class="relative w-full max-w-2xl">
        <!-- Progress Info -->
        <div class="mb-8 pl-1">
            <h2 class="text-sm font-semibold text-cyan-400 tracking-wider uppercase mb-3"><%= testTitle %></h2>
            <div class="flex justify-between items-end mb-2">
                <span class="text-2xl font-bold text-white">Câu <%= id %> <span class="text-slate-500 text-lg font-medium">/ <%= total %></span></span>
                <span class="text-sm text-slate-400 font-medium"><%= Math.round((id / total) * 100) %>% hoàn thành</span>
            </div>
            
            <!-- Progress Bar -->
            <div class="h-2 w-full bg-slate-800 rounded-full overflow-hidden shadow-inner">
                <div class="h-full bg-gradient-to-r from-cyan-500 to-emerald-400 transition-all duration-500 ease-out" 
                     style="width: <%= (id / total) * 100 %>%"></div>
            </div>
        </div>

        <!-- Question Card -->
        <div class="bg-slate-800/80 backdrop-blur-md ring-1 ring-white/10 rounded-3xl p-8 md:p-10 shadow-2xl">
            <h3 class="text-2xl md:text-3xl font-semibold text-white leading-relaxed mb-8">
                <%= question.title %>
            </h3>

            <form action="/question/<%= id %>" method="POST" class="space-y-4">
                <% const options = ['A', 'B', 'C', 'D', 'E', 'F']; %>
                
                <div class="space-y-3">
                    <% options.forEach(opt => { %>
                        <% if (question[opt]) { %>
                            <label class="group relative flex items-center p-5 border border-slate-700/50 rounded-2xl cursor-pointer bg-slate-800/40 hover:bg-slate-700 hover:border-cyan-500/30 transition-all duration-200">
                                <input type="radio" name="answer" value="<%= opt %>" required
                                       class="peer sr-only">
                                
                                <div class="w-6 h-6 mr-4 rounded-full border-2 border-slate-600 group-hover:border-cyan-400 peer-checked:border-cyan-500 peer-checked:bg-cyan-500 transition-all flex items-center justify-center">
                                    <div class="w-2 h-2 rounded-full bg-slate-900 opacity-0 peer-checked:opacity-100 transition-opacity"></div>
                                </div>
                                
                                <div class="flex-1">
                                    <span class="text-lg text-slate-300 peer-checked:text-white peer-checked:font-medium transition-colors">
                                        <span class="font-bold text-slate-500 mr-2"><%= opt %>.</span> <%= question[opt] %>
                                    </span>
                                </div>
                                
                                <div class="absolute inset-0 rounded-2xl ring-2 ring-transparent peer-checked:ring-cyan-500/50 peer-checked:bg-cyan-500/5 transition-all pointer-events-none"></div>
                            </label>
                        <% } %>
                    <% }); %>
                </div>

                <div class="mt-10 pt-6 border-t border-slate-700/50 flex justify-end">
                    <button type="submit" class="group relative inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-slate-900 bg-cyan-400 rounded-xl overflow-hidden hover:bg-cyan-300 transition-colors shadow-[0_0_15px_rgba(34,211,238,0.4)] hover:shadow-[0_0_25px_rgba(34,211,238,0.6)] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-900 focus:ring-cyan-400">
                        <span class="relative">
                            <%= id < total ? 'Tiếp tục' : 'Xem Kết Quả' %>
                        </span>
                        <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>
    
</body>
</html>